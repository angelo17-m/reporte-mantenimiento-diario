<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reporte Diario - Chuquicamata</title>
    <style>
        :root { --copper: #E05206; --bg: #0b0b0b; --card: #1a1a1a; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: white; padding: 10px; margin: 0; }
        .container { max-width: 500px; margin: 10px auto; background: var(--card); border-radius: 12px; border-top: 5px solid var(--copper); box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .form-content { padding: 20px; }
        .step { display: none; }
        .step.active { display: block; animation: fadeIn 0.3s; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        label { display: block; margin: 15px 0 5px; font-weight: bold; color: #ccc; font-size: 0.9rem; }
        input, select, textarea { width: 100%; padding: 12px; border: 1px solid #333; border-radius: 8px; background: #252525; color: white; box-sizing: border-box; font-size: 1rem; }
        .btn-group { display: flex; gap: 10px; margin-top: 25px; }
        .btn { flex: 1; padding: 15px; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; text-transform: uppercase; }
        .btn-next { background: var(--copper); color: white; }
        .btn-prev { background: #444; color: white; }
        .btn-submit { background: #28a745; color: white; width: 100%; margin-top: 20px; font-size: 1.1rem; }
        .loader { display: none; text-align: center; color: var(--copper); font-weight: bold; margin-top: 15px; border: 1px solid var(--copper); padding: 10px; border-radius: 8px; }
        option { background: #1a1a1a; }
    </style>
</head>
<body>

<div class="container">
    <div class="form-content">
        <h2 style="text-align:center; color:var(--copper);">REPORTE DIARIO DE MANTENIMIENTO</h2>
        <form id="mainForm">
            
            <div class="step active" id="s1">
                <label>Nombre Completo *</label>
                <input type="text" id="nombre" required placeholder="Ej: Angelo Arancibia">
                <label>Número de OT</label>
                <input type="text" id="ot" placeholder="Ej: 123456">
                <label>Cargo</label>
                <input type="text" id="cargo" placeholder="Ej: Mecánico">
                <div class="btn-group"><button type="button" class="btn btn-next" onclick="move(2)">Siguiente</button></div>
            </div>

            <div class="step" id="s2">
                <label>Empresa</label>
                <select id="empresa">
                    <option value="Codelco">Codelco</option>
                    <option value="Metso">Metso</option>
                    <option value="Nexxo">Nexxo</option>
                    <option value="SKF">SKF</option>
                    <option value="Schwager">Schwager</option>
                    <option value="Cimap">Cimap</option>
                </select>
                <div class="btn-group"><button type="button" class="btn btn-prev" onclick="move(1)">Atrás</button><button type="button" class="btn btn-next" onclick="move(3)">Siguiente</button></div>
            </div>

            <div class="step" id="s3">
                <label>Equipo intervenido</label>
                <select id="equipo">
                    <optgroup label="HARNEROS">
                        <option value="Harn15/F900-1">Harn15/F900-1</option><option value="Harn25/F900-1">Harn25/F900-1</option>
                    </optgroup>
                    <optgroup label="OTROS F900">
                        <option value="F900-3">F900-3</option><option value="F900-3A">F900-3A</option>
                        <option value="Harn45/F900-4">Harn45/F900-4</option><option value="Harn5S/F900-5">Harn5S/F900-5</option>
                    </optgroup>
                    <optgroup label="HarnF600 Series">
                        <option value="HarnF600 1A">HarnF600 1A</option><option value="HarnF600 2A">HarnF600 2A</option>
                        <option value="HarnF600 3A">HarnF600 3A</option><option value="HarnF600 4A">HarnF600 4A</option>
                        <option value="HarnF600 5A">HarnF600 5A</option><option value="HarnF600 6A">HarnF600 6A</option>
                        <option value="HarnF600 7A">HarnF600 7A</option><option value="HarnF600 8A">HarnF600 8A</option>
                        <option value="HarnF600 9A">HarnF600 9A</option><option value="HarnF600 10A">HarnF600 10A</option>
                        <option value="HarnF600 3B">HarnF600 3B</option><option value="HarnF600 4B">HarnF600 4B</option>
                        <option value="HarnF600 5B">HarnF600 5B</option><option value="HarnF600 6B">HarnF600 6B</option>
                        <option value="HarnF600 7B">HarnF600 7B</option><option value="HarnF600 8B">HarnF600 8B</option>
                        <option value="HarnF600 9B">HarnF600 9B</option><option value="HarnF600 10B">HarnF600 10B</option>
                    </optgroup>
                    <optgroup label="Chancadores y Nodos">
                        <option value="ChaS1">ChaS1</option><option value="ChaS2">ChaS2</option><option value="ChaS3">ChaS3</option>
                        <option value="ChaS4">ChaS4</option><option value="ChaS5">ChaS5</option>
                        <option value="ChaT1">ChaT1</option><option value="ChaT2">ChaT2</option><option value="ChaT3">ChaT3</option>
                        <option value="ChaT4">ChaT4</option><option value="ChaT5">ChaT5</option><option value="ChaT6">ChaT6</option>
                        <option value="ChaT7">ChaT7</option><option value="ChaT8">ChaT8</option><option value="ChaT9">ChaT9</option>
                        <option value="ChaT10">ChaT10</option><option value="NODO 1">NODO 1</option><option value="NODO 2">NODO 2</option><option value="NODO 3">NODO 3</option>
                    </optgroup>
                    <optgroup label="Correas CT">
                        <option value="C/135A">C/135A</option><option value="C/1A">C/1A</option><option value="C/2A">C/2A</option>
                        <option value="C/11A">C/11A</option><option value="C/22A">C/22A</option><option value="C/140A">C/140A</option>
                        <option value="C/141A">C/141A</option><option value="C/140">C/140</option><option value="C/141">C/141</option>
                        <option value="C/142">C/142</option><option value="C/136A">C/136A</option><option value="C/136B">C/136B</option>
                        <option value="C/136C">C/136C</option><option value="C/144">C/144</option><option value="C/137A">C/137A</option>
                        <option value="C/137">C/137</option><option value="C/135B">C/135B</option><option value="C/135C">C/135C</option>
                        <option value="C/135D">C/135D</option><option value="C/136">C/136</option><option value="C/138">C/138</option>
                        <option value="C/139">C/139</option><option value="C/143">C/143</option><option value="C/135E">C/135E</option>
                        <option value="C/134A">C/134A</option><option value="C/134B">C/134B</option><option value="C/134C">C/134C</option>
                        <option value="C/134D">C/134D</option><option value="C/134E">C/134E</option>
                    </optgroup>
                    <optgroup label="Otros">
                        <option value="Carro norte (CT137)">Carro norte (CT137)</option>
                        <option value="Carro sur (CT137 A)">Carro sur (CT137 A)</option>
                        <option value="Fabricación/Reparación estructuras">Fabricación/Reparación estructuras</option>
                        <option value="Housekeeping">Housekeeping</option>
                    </optgroup>
                </select>
                <div class="btn-group"><button type="button" class="btn btn-prev" onclick="move(2)">Atrás</button><button type="button" class="btn btn-next" onclick="move(4)">Siguiente</button></div>
            </div>

            <div class="step" id="s4">
                <label>Foto Housekeeping (Galería o Cámara)</label>
                <input type="file" id="fHK" accept="image/*">
                <div class="btn-group"><button type="button" class="btn btn-prev" onclick="move(3)">Atrás</button><button type="button" class="btn btn-next" onclick="move(5)">Siguiente</button></div>
            </div>

            <div class="step" id="s5">
                <label>¿Se utilizaron repuestos?</label>
                <select id="ocupoRepuestos" onchange="toggleRepuestos()">
                    <option value="NO">NO</option><option value="SI">SI</option>
                </select>
                <div id="repDiv" style="display:none; margin-top:10px;">
                    <label>Listado de repuestos</label>
                    <textarea id="queRepuestos" rows="3" placeholder="Ej: 2 rodillos, 1 polín..."></textarea>
                </div>
                <div class="btn-group"><button type="button" class="btn btn-prev" onclick="move(4)">Atrás</button><button type="button" class="btn btn-next" onclick="move(6)">Siguiente</button></div>
            </div>

            <div class="step" id="s6">
                <label>¿Con cuántas personas trabajaste?</label>
                <select id="nPersonas">
                    <option value="1 trabajador">1 trabajador</option>
                    <option value="2 trabajadores">2 trabajadores</option>
                    <option value="3 trabajadores">3 trabajadores</option>
                    <option value="4 trabajadores">4 trabajadores</option>
                    <option value="5 trabajadores">5 trabajadores</option>
                    <option value="6 trabajadores">6 trabajadores</option>
                    <option value="7 trabajadores">7 trabajadores</option>
                    <option value="8 trabajadores">8 trabajadores</option>
                    <option value="9 trabajadores">9 trabajadores</option>
                    <option value="10 trabajadores">10 trabajadores</option>
                    <option value="11 trabajadores">11 trabajadores</option>
                    <option value="12 trabajadores">12 trabajadores</option>
                    <option value="13 trabajadores">13 trabajadores</option>
                    <option value="14 trabajadores">14 trabajadores</option>
                    <option value="15 trabajadores">15 trabajadores</option>
                </select>
                
                <label>Horas totales trabajadas</label>
                <select id="horas">
                    <option value="1hr">1hr</option>
                    <option value="2hr">2hr</option>
                    <option value="3hr">3hr</option>
                    <option value="4hr">4hr</option>
                    <option value="5hr">5hr</option>
                    <option value="6hr">6hr</option>
                    <option value="7hr">7hr</option>
                    <option value="8hr">8hr</option>
                    <option value="9hr">9hr</option>
                    <option value="10hr">10hr</option>
                    <option value="11hr">11hr</option>
                    <option value="12hr">12hr</option>
                    <option value="13hr">13hr</option>
                    <option value="14hr">14hr</option>
                    <option value="15hr">15hr</option>
                </select>
                
                <div class="btn-group"><button type="button" class="btn btn-prev" onclick="move(5)">Atrás</button><button type="button" class="btn btn-next" onclick="move(7)">Siguiente</button></div>
            </div>

            <div class="step" id="s7">
                <label>¿Trabajo planificado?</label>
                <select id="planificado"><option value="SI">SI</option><option value="NO">NO</option></select>
                <label>Estado del trabajo</label>
                <select id="terminado" onchange="toggleMotivo()">
                    <option value="SI">TERMINADO</option>
                    <option value="NO">PENDIENTE</option>
                    <option value="EN CURSO">EN CURSO</option>
                </select>
                <div id="motDiv" style="display:none; margin-top:10px;">
                    <label>Motivo del estado actual</label>
                    <textarea id="motivoNoTerminado" rows="2" placeholder="Ej: Falta de repuesto"></textarea>
                </div>
                <div class="btn-group"><button type="button" class="btn btn-prev" onclick="move(6)">Atrás</button><button type="button" class="btn btn-next" onclick="move(8)">Siguiente</button></div>
            </div>

            <div class="step" id="s8">
                <label>Foto de la Actividad</label>
                <input type="file" id="fAct" accept="image/*">
                
                <label>Foto ART</label>
                <input type="file" id="fART" accept="image/*">

                <label>Foto Plan de Izaje (Opcional)</label>
                <input type="file" id="fIzaje" accept="image/*">

                <div class="btn-group"><button type="button" class="btn btn-prev" onclick="move(7)">Atrás</button></div>
                <button type="submit" id="btnSubmit" class="btn btn-submit">ENVIAR REPORTE DIARIO</button>
                <div id="loader" class="loader">Procesando y enviando... por favor espera.</div>
            </div>
        </form>
    </div>
</div>

<script>
    const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbzWlDa7jNC_DSKbP_cdQz-FF4YSX8SCuv5bnIly2VP15SbKFEfT2OgTxrb_s0SNkufZ/exec";

    function move(n) {
        document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
        document.getElementById('s' + n).classList.add('active');
        window.scrollTo(0,0);
    }

    function toggleRepuestos() {
        const val = document.getElementById('ocupoRepuestos').value;
        document.getElementById('repDiv').style.display = (val === 'SI') ? 'block' : 'none';
    }

    function toggleMotivo() {
        const val = document.getElementById('terminado').value;
        document.getElementById('motDiv').style.display = (val === 'SI') ? 'none' : 'block';
    }

    async function processImage(file) {
        return new Promise((resolve) => {
            if (!file) return resolve("");
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = (event) => {
                const img = new Image();
                img.src = event.target.result;
                img.onload = () => {
                    const canvas = document.createElement('canvas');
                    const MAX_WIDTH = 400; 
                    const scaleSize = MAX_WIDTH / img.width;
                    canvas.width = MAX_WIDTH;
                    canvas.height = img.height * scaleSize;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                    resolve(canvas.toDataURL('image/jpeg', 0.6));
                };
            };
        });
    }

    document.getElementById('mainForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('btnSubmit');
        const ldr = document.getElementById('loader');
        
        btn.disabled = true; 
        ldr.style.display = 'block';

        const payload = {
            nombre: document.getElementById('nombre').value,
            ot: document.getElementById('ot').value,
            cargo: document.getElementById('cargo').value,
            empresa: document.getElementById('empresa').value,
            equipo: document.getElementById('equipo').value,
            planificado: document.getElementById('planificado').value,
            nPersonas: document.getElementById('nPersonas').value,
            horas: document.getElementById('horas').value,
            ocupoRepuestos: document.getElementById('ocupoRepuestos').value,
            queRepuestos: document.getElementById('queRepuestos').value || "Ninguno",
            terminado: document.getElementById('terminado').value,
            motivoNoTerminado: document.getElementById('motivoNoTerminado').value || "N/A",
            fotoHK: await processImage(document.getElementById('fHK').files[0]),
            fotoAct: await processImage(document.getElementById('fAct').files[0]),
            fotoART: await processImage(document.getElementById('fART').files[0]),
            fotoIzaje: await processImage(document.getElementById('fIzaje').files[0])
        };

        try {
            await fetch(SCRIPT_URL, {
                method: 'POST',
                mode: 'no-cors',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            alert("✅ ¡Éxito! El reporte se guardó en la nube.");
            location.reload();

        } catch (error) {
            alert("❌ Error al enviar. Verifica tu conexión.");
            btn.disabled = false; 
            ldr.style.display = 'none';
        }
    });
</script>
</body>
</html>
